{
  "name": "sa-chatbot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": "22.x",
    "npm": ">=10"
  },
  "scripts": {
    "check:runtime": "node scripts/check-runtime.mjs",
    "predev": "npm run check:runtime",
    "dev": "NODE_ENV=development next dev --webpack",
    "prebuild": "npm run check:runtime",
    "build": "NODE_ENV=production next build",
    "prestart": "npm run check:runtime",
    "start": "NODE_ENV=production next start",
    "prelint": "npm run check:runtime",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "node --import tsx --test 'src/**/*.test.ts' 'src/**/*.test.tsx'",
    "audit:vector-pipeline": "node scripts/audit-vector-pipeline.mjs",
    "transcribe": "node scripts/transcribe.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.94.0",
    "@heroui/react": "^3.1.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "2.105.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "4.20.6",
    "typescript": "^5"
  }
}
