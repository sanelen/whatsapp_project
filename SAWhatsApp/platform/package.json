{
  "name": "platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "check:runtime": "node scripts/check-runtime.mjs",
    "predev": "npm run check:runtime",
    "dev": "NODE_ENV=development next dev --webpack",
    "prebuild": "npm run check:runtime",
    "build": "NODE_ENV=production next build",
    "prestart": "npm run check:runtime",
    "start": "NODE_ENV=production next start",
    "prelint": "npm run check:runtime",
    "lint": "eslint",
    "pretypecheck": "npm run check:runtime",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "twilio": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
